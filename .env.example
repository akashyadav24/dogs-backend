# Copy this file to `.env` and fill in the values. The server reads these at startup.

# MongoDB connection string. IMPORTANT: include the database name (/dogs) in the
# path — Mongoose uses it to select the database.
# - Local:  mongodb://127.0.0.1:27017/dogs
# - Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/dogs?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/dogs

# Port the API listens on (most hosts set this automatically in production).
PORT=4000

# Environment: development | production
NODE_ENV=development
